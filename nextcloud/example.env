# Location for data 
DATA_LOCATION=

# Host directory to mount into Nextcloud containers
NEXTCLOUD_MOUNT=/mnt

# IP Address for hosting nextcloud
APACHE_IP_BINDING=

# --- Nextcloud MCP Server (Login Flow v2 / multi-user OAuth) ---
# Each user authenticates via OAuth and the server provisions a per-user Nextcloud
# app password, so people use their own Nextcloud accounts. No shared
# NEXTCLOUD_USERNAME/PASSWORD is used in this mode.

# Host port published for nginxproxymanager to front (container listens on 8000)
NEXTCLOUD_MCP_PORT=8009

# Persistent data root for the encrypted per-user token DB
DATA_DIR=/opt/stacks/nextcloud

# Data leg: how the MCP server reaches Nextcloud (public HTTPS URL is simplest)
NEXTCLOUD_HOST=https://cloud.example.com

# Public, browser-facing URLs for OAuth redirects and issuer validation
NEXTCLOUD_MCP_SERVER_URL=https://ncmcp.example.com
NEXTCLOUD_PUBLIC_ISSUER_URL=https://cloud.example.com

# OIDC client the MCP server uses with the IdP.
# For Nextcloud-as-IdP: Admin settings -> OpenID Connect provider -> Add client
#   Redirect URI:  https://ncmcp.example.com/oauth/callback
#   Resource id:   https://ncmcp.example.com/mcp
#   Type: confidential, flow: authorization code
NEXTCLOUD_OIDC_CLIENT_ID=
NEXTCLOUD_OIDC_CLIENT_SECRET=

# Fernet key encrypting stored per-user app passwords. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: losing this key forces every user to re-provision.
TOKEN_ENCRYPTION_KEY=

# --- Optional: external IdP (e.g. Authentik) instead of Nextcloud-as-IdP ---
# Uncomment the matching lines in docker-compose.yml, then set these:
# OIDC_DISCOVERY_URL=https://authentik.example.com/application/o/nextcloud-mcp/.well-known/openid-configuration
# NEXTCLOUD_PUBLIC_URL=https://cloud.example.com
