# Portainer stack data root for n8n state and workflow files.
DATA_DIR=/opt/stacks/n8n

N8N_IMAGE=docker.n8n.io/n8nio/n8n:stable
N8N_BIND_IP=0.0.0.0
N8N_PORT=5678

# Use http for direct LAN access. Switch to https when a reverse proxy terminates TLS for n8n.
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/

GENERIC_TIMEZONE=America/Chicago

# Required: generate and keep this stable; losing it breaks stored credentials.
N8N_ENCRYPTION_KEY=

# Set true only when browsers access n8n exclusively through HTTPS.
N8N_SECURE_COOKIE=false
