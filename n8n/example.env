# Portainer stack data root for n8n state, PostgreSQL, workflow files, and local backups.
DATA_DIR=/opt/stacks/n8n

N8N_IMAGE=docker.n8n.io/n8nio/n8n:stable
POSTGRES_IMAGE=postgres:16-alpine
N8N_BIND_IP=0.0.0.0
N8N_PORT=5678

# Use HTTP only for direct LAN access. Switch to HTTPS when a reverse proxy terminates TLS.
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false

GENERIC_TIMEZONE=America/Chicago

POSTGRES_DB=n8n
POSTGRES_USER=n8n
# Required: set a unique, non-empty password in Portainer. Do not commit it.
POSTGRES_PASSWORD=

# Required: generate once and keep this stable; losing it breaks stored n8n credentials.
N8N_ENCRYPTION_KEY=
