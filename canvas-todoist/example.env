# Private Canvas Calendar Feed URL:
# Canvas > Calendar > "Calendar Feed" (bottom right) > copy the .ics link
CANVAS_ICS_URL=

# Todoist > Settings > Integrations > Developer > API token
TODOIST_API_TOKEN=

# Todoist project that receives assignments (created if missing)
TODOIST_PROJECT=School

# Seconds between syncs
SYNC_INTERVAL=3600

# Skip assignments due more than this many days in the past
PAST_DUE_DAYS=3

TZ=America/Chicago
