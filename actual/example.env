ACTUAL_DATA_DIR=/opt/stacks/actual/data
ACTUAL_IMAGE=docker.io/actualbudget/actual-server:latest
ACTUAL_PORT=5006

# Actual MCP companion service
ACTUAL_MCP_IMAGE=sstefanov/actual-mcp:latest
ACTUAL_MCP_PORT=3000
ACTUAL_MCP_DATA_DIR=/opt/stacks/actual-mcp/data
ACTUAL_MCP_ACTUAL_SERVER_URL=http://actual_server:5006
ACTUAL_MCP_ACTUAL_PASSWORD=
ACTUAL_MCP_BUDGET_SYNC_ID=
# Optional: if the budget encryption/unlock password differs from ACTUAL_MCP_ACTUAL_PASSWORD.
ACTUAL_MCP_BUDGET_ENCRYPTION_PASSWORD=
# Required because the MCP service starts with --enable-bearer.
ACTUAL_MCP_BEARER_TOKEN=
