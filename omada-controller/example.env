DATA_DIR=/opt/stacks/omada-controller
OMADA_IMAGE=mbentley/omada-controller:6.2
TZ=Etc/UTC

OMADA_PUID=508
OMADA_PGID=508

OMADA_MANAGE_HTTP_PORT=8088
OMADA_MANAGE_HTTPS_PORT=8043
OMADA_PORTAL_HTTP_PORT=8088
OMADA_PORTAL_HTTPS_PORT=8843
OMADA_UPGRADE_HTTPS_PORT=8043
OMADA_PORT_APP_DISCOVERY=27001
OMADA_PORT_DISCOVERY=29810
OMADA_PORT_MANAGER_V1=29811
OMADA_PORT_ADOPT_V1=29812
OMADA_PORT_UPGRADE_V1=29813
OMADA_PORT_MANAGER_V2=29814
OMADA_PORT_TRANSFER_V2=29815
OMADA_PORT_RTTY=29816
OMADA_PORT_DEVICE_MONITOR=29817

OMADA_WEB_CONFIG_OVERRIDE=false
OMADA_SHOW_SERVER_LOGS=true
OMADA_SHOW_MONGODB_LOGS=false
OMADA_SSL_CERT_NAME=tls.crt
OMADA_SSL_KEY_NAME=tls.key

# Conservative defaults for small hosts. Increase if the controller is under memory pressure.
OMADA_JAVA_MAX_HEAP_SIZE=512m
OMADA_JAVA_MIN_HEAP_SIZE=128m
OMADA_MONGOD_EXTRA_ARGS=--wiredTigerCacheSizeGB 0.25
