# Stable host path for Open Design application state.
DATA_DIR=/opt/stacks/opendesign

# Open Design image name/tag produced by the Compose build.
OPEN_DESIGN_IMAGE=opendesign:latest

# Build from the upstream Open Design repository. Pin to a release/tag if you want deterministic rebuilds.
OPEN_DESIGN_BUILD_CONTEXT=https://github.com/nexu-io/open-design.git#main

# Host IP/port to publish. Use 0.0.0.0 for LAN/reverse-proxy access, or 127.0.0.1 for local-only.
OPEN_DESIGN_BIND_IP=0.0.0.0
COMPOSE_PORT_HTTP=7456

# Optional hardening/configuration.
# Browser/API origin allowed by Open Design when served behind the reverse proxy.
OPEN_DESIGN_ALLOWED_ORIGINS=https://design.papatenko.org
OD_API_TOKEN=
OPEN_DESIGN_DISABLE_API_AUTH=
OD_CODEX_SANDBOX=
NODE_OPTIONS=--max-old-space-size=192
OPEN_DESIGN_MEM_LIMIT=384m
