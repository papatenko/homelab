# Stable host path for downloaded Whisper model cache.
DATA_DIR=/opt/stacks/whisper

# The OpenAI Whisper model to load. Options include tiny, base, small, medium, large.
ASR_MODEL=small

# Host port to publish. Put a reverse proxy in front for HTTPS/remote access.
COMPOSE_PORT_HTTP=9000

# Optional image override if you want to pin a tag/digest later.
WHISPER_IMAGE=onerahmet/openai-whisper-asr-webservice:latest
