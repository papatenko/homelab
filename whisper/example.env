# Stable host path for downloaded Whisper model cache and server state.
DATA_DIR=/opt/stacks/whisper

# OpenAI-compatible Whisper server image. Use :cuda only on hosts with NVIDIA runtime configured.
WHISPER_IMAGE=hwdsl2/whisper-server:latest

# The Whisper model to load. Options include tiny, base, small, medium, large-v3, large-v3-turbo.
WHISPER_MODEL=small
WHISPER_LANGUAGE=auto
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_THREADS=2
WHISPER_LOG_LEVEL=INFO
WHISPER_DISABLE_USAGE_COUNTS=1

# Set a real secret in Portainer for internet-facing deployments.
# Leave blank only for trusted/VPN-only access.
WHISPER_API_KEY=

# Host port to publish. Put a reverse proxy in front for HTTPS/remote access.
COMPOSE_PORT_HTTP=9000
