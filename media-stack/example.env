# Common
PUID=1000
PGID=1000
TZ=America/Chicago
DATA_DIR=/mnt/misc/media
MEDIA_ROOT=/mnt/misc/media
# Required download directory; set this in Portainer for the deployment host.
DOWNLOAD_PATH=
CUSTOM_FONTS=/usr/share/fonts/truetype
PUBLISHED_URL=https://jellyfin.papatenko.org
# Set to vpn only after all WireGuard values below are configured in Portainer.
COMPOSE_PROFILES=

# WireGuard provider configuration for gluetun/qBittorrent.
# Keep these values in Portainer stack environment variables or a secret store;
# do not commit a populated env file.
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=
WIREGUARD_PUBLIC_KEY=
WIREGUARD_ENDPOINT_IP=
WIREGUARD_ENDPOINT_PORT=51820
WIREGUARD_PERSISTENT_KEEPALIVE=25
